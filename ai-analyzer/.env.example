ANTHROPIC_API_KEY=your_api_key
ANTHROPIC_MODEL=your_api_key

# GPT Image 1 — image generation only (idea/text generation stays on Anthropic)
IMAGE_GPT_API_KEY=your_openai_api_key
OPENAI_IMAGE_MODEL=gpt-image-1

# Agentic Mode — direct Supabase tool (slot-collision check + draft insert).
# Same project as backend/.env's SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
