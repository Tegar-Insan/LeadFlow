# ─────────────────────────────────────────────────────────────
# LeadFlow Backend — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

PORT=5001
NODE_ENV=development

# Supabase (Session Pooler — ap-southeast-1, port 6543)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anonkey
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
DATABASE_URL=postgresql:your_postgresql_url (Connect to supabase first)
SUPABASE_STORAGE_BUCKET=leadflow-media

# JWT
JWT_SECRET=xyour_jwt_secret key
JWT_EXPIRES=your_expires
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_EXPIRES_MINUTES=10

# SMTP (for OTP emails)
SMTP_HOST="it should be your domain"
SMTP_PORT="it must integer"
SMTP_SECURE= "boolean operator"
SMTP_USER=your_email
SMTP_PASS=wwradypfsyqzdlvs
EMAIL_FROM="up_to_you <noreply@leadflow.id>"

# Frontend URL (CORS whitelist)
FRONTEND_URL=http://localhost:5173

# Anthropic
ANTHROPIC_API_KEY=your_api_key
ANTHROPIC_MODEL=preferre_model

# ai-analyzer (Python FastAPI) — image generation + Agentic Mode proxy target
AI_SERVICE_URL=http://127.0.0.1:8000

#TikTok Data Scraper API
BRIGHTDATA_KEY= your_brightdata_key
BRIGHTDATA_DATASET_ID = dataset_id

# TikTok Login Kit v2
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:5000/api/tiktok/callback
TIKTOK_MEDIA_PUBLIC_BASE_URL=https://your-verified-domain.example
# ^ Must be a domain verified under TikTok Developer Portal "URL properties"
# for this app (Content Posting API requires PULL_FROM_URL sources to come
# from a verified domain/URL prefix). Bare origin only — /tiktok/public/media/:id
# is appended in code. Requests to that route now require a signed ?token=
# query param (see backend/src/utils/mediaTokenHelper.ts) since it sits behind
# a permanent public domain instead of a throwaway tunnel.
TIKTOK_SITE_VERIFICATION_TOKEN=your_current_tiktok_verification_token
TIKTOK_TOKEN_ENCRYPTION_KEY=generate_via_openssl_rand_hex_32
FRONTEND_BASE_URL=http://localhost:5173

# Timezone
TZ=Asia/Jakarta
