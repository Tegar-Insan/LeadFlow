# ─────────────────────────────────────────────────────────────
# LeadFlow Backend — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# Supabase (Session Pooler — ap-southeast-1, port 6543)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anonkey
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
DATABASE_URL=postgresql:your_postgresql_url (Connect to supabase first)
SUPABASE_STORAGE_BUCKET=storage_bucket

# JWT
JWT_SECRET=xyour_jwt_secret key
JWT_EXPIRES=your_expires
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_EXPIRES_MINUTES=10

# SMTP (for OTP emails)
SMTP_HOST="it should be your domain"
SMTP_PORT="it must integer"
SMTP_SECURE= "boolean operator"
SMTP_USER=your_email
SMTP_PASS=wwradypfsyqzdlvs
EMAIL_FROM="up_to_you <noreply@leadflow.id>"

# Frontend URL (CORS whitelist)
FRONTEND_URL=http://localhost:5173

# Anthropic
ANTHROPIC_API_KEY=your_api_key
ANTHROPIC_MODEL=preferre_model

#TikTok Data Scraper API
BRIGHTDATA_KEY= your_brightdata_key
BRIGHTDATA_DATASET_ID = dataset_id

# tiktok connector
TIKTOK_CLIENT_KEY=your-tiktok-app-id
TIKTOK_CLIENT_SECRET=your_client_tiktok_key
TIKTOK_REDIRECT_URI= your_local_host

# Timezone
TZ=Asia/Jakarta
